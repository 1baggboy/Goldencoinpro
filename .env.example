# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="AIzaSyBav7GgL0YR3mKsQSOlwioTuHxl0zqat5E"

# VITE_GEMINI_API_KEY: Required for client-side Gemini AI features on Vercel.
# On Vercel, navigate to Project Settings -> Environment Variables to add this.
VITE_GEMINI_API_KEY="AIzaSyBav7GgL0YR3mKsQSOlwioTuHxl0zqat5E"

# RESEND_API_KEY: Required for sending login notification emails.
# Sign up at resend.com and obtain an API key.
RESEND_API_KEY="re_QJd5BJyY_KtbMGC9uiGboY44kezHPcfhD"

# RESEND_FROM_DOMAIN: The domain you have verified in Resend (e.g., goldencoin.live).
# If you are in testing mode without a verified domain, you might need to use resend.dev.
RESEND_FROM_DOMAIN="goldencoin.live"

# JWT_SECRET: Secret key used to sign JSON Web Tokens.
JWT_SECRET="your_jwt_secret_here"

# FRONTEND_URL: The URL where your frontend is hosted (e.g., https://goldencoin.live).
FRONTEND_URL="https://goldencoin.live"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID="your_project_id"
FIREBASE_PRIVATE_KEY="your_private_key"
FIREBASE_CLIENT_EMAIL="your_client_email"

# Firebase Client SDK Configuration
FIREBASE_API_KEY="your_api_key"
FIREBASE_AUTH_DOMAIN="your_auth_domain"
FIREBASE_STORAGE_BUCKET="your_storage_bucket"
FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
FIREBASE_APP_ID="your_app_id"
