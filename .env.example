# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="AIzaSyBav7GgL0YR3mKsQSOlwioTuHxl0zqat5E"

# VITE_GEMINI_API_KEY: Required for client-side Gemini AI features on Vercel.
# On Vercel, navigate to Project Settings -> Environment Variables to add this.
VITE_GEMINI_API_KEY="AIzaSyBav7GgL0YR3mKsQSOlwioTuHxl0zqat5E"

# RESEND_API_KEY: Required for sending login notification emails.
# Sign up at resend.com and obtain an API key.
RESEND_API_KEY="re_QJd5BJyY_KtbMGC9uiGboY44kezHPcfhD"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration for OTP emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
