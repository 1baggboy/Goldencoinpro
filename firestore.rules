rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "lookuptoadams@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'btcBalance', 'kycStatus']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.btcBalance is number &&
             data.kycStatus in ['not_submitted', 'pending', 'verified', 'rejected'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'status', 'timestamp']) &&
             data.userId is string &&
             data.type in ['deposit', 'withdrawal'] &&
             data.amount is number &&
             data.status in ['pending', 'confirmed', 'failed'];
    }

    function isValidKYC(data) {
      return data.keys().hasAll(['userId', 'fullName', 'idType', 'status', 'submittedAt', 'idImage', 'selfieImage']) &&
             data.userId is string &&
             data.fullName is string &&
             data.idType in ['passport', 'national_id', 'drivers_license'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.idImage is string &&
             data.selfieImage is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'timestamp']) &&
             data.userId is string &&
             data.title is string &&
             data.message is string &&
             data.type in ['info', 'success', 'warning', 'error'] &&
             data.read is bool &&
             data.timestamp is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user' && request.resource.data.status == 'active';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.btcBalance == resource.data.btcBalance && request.resource.data.status == resource.data.status);
    }

    // Transactions Collection
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isAuthenticated() && request.query.limit <= 100); // Allow admins to list all, users to list their own (filtered by query)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTransaction(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // KYC Submissions Collection
    match /kyc_submissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidKYC(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Investments Collection
    match /investments/{investmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isAuthenticated() && request.query.limit <= 100);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'active';
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'completed' && resource.data.status == 'active');
      allow delete: if false;
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin()) && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
