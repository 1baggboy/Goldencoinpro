rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "info.goldencoinltd@gmail.com" ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == "info.goldencoinltd@gmail.com");
    }

    function existingData() {
      return resource.data;
    }

    function incomingData() {
      return request.resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admin collection
    match /admins/{adminId} {
      allow read: if isSignedIn(); // Allow checking if self is admin
      allow write: if false; // Only manageable via console
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isOwner(userId) && (
        // Owners can only update specific profile fields
        incomingData().diff(existingData()).affectedKeys().hasOnly([
          'name', 'displayName', 'firstName', 'lastName', 'phoneNumber', 'country', 'city', 'address', 
          'gender', 'photoURL', 'avatarUrl', 'kycStatus', 'lastLogin', 'updatedAt', 'twoFactorEnabled', 
          'isOnline',
          'tradingBalanceBtc', 'btcBalance', 'usdBalance', 'totalDeposited', 
          'referralBonusEarned', 'status', 'referralCode', 'referredBy', 'hasTraded'
        ])
      ));
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Transactions collection
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Relaxed create rule to ensure deposits and withdrawals can be submitted
      allow create: if isSignedIn() && 
                   incomingData().userId == request.auth.uid && 
                   (incomingData().status in ['PENDING', 'pending', 'SUCCESS', 'success']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // KYC Submissions
    match /kyc_submissions/{kycId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incomingData().userId == request.auth.uid && incomingData().status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Investments
    match /investments/{invId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incomingData().userId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(existingData().userId) && incomingData().diff(existingData()).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    // Support Chats
    match /support_chats/{msgId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incomingData().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Support Tickets (legacy/alternative)
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (isOwner(existingData().userId) || isAdmin());
      allow create: if isSignedIn() && incomingData().userId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(existingData().userId) && incomingData().diff(existingData()).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }
    
    match /support_tickets/{ticketId}/messages/{msgId} {
      allow read: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incomingData().userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Contact Messages
    match /contact_messages/{msgId} {
      allow create: if true;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // Deleted Accounts (Security audit)
    match /deletedAccounts/{emailSlug} {
      allow create, update, delete: if isSignedIn();
      allow read: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    // Email Logs
    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Backend service creates these
      allow delete: if isAdmin();
    }

    // System config & stats
    match /system/stats {
      allow read: if true;
    }
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Public Mail (for extensions)
    match /mail/{mailId} {
      allow create: if true; // Used by frontend services
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // Newsletters
    match /newsletters/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /chat_messages/{msgId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /contact_submissions/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
